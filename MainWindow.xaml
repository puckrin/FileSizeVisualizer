<Window x:Class="FileSizeVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FileSizeVisualizer.Converters"
        xmlns:viewmodels="clr-namespace:FileSizeVisualizer.ViewModels"
        Title="File Size Visualizer"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:PercentageConverter x:Key="PercentageConverter"/>
        <converters:ProportionalWidthConverter x:Key="ProportionalWidthConverter"/>
        <converters:HeightConverter x:Key="HeightConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="Open" Click="OpenFile_Click"/>
            <MenuItem Header="Delete" Click="DeleteFile_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Folder Tree -->
        <DockPanel Grid.Column="0" Margin="8">
            <TextBlock DockPanel.Dock="Top"
                       Text="Folders"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,8"/>

            <Button DockPanel.Dock="Bottom"
                    x:Name="RescanButton"
                    Content="Rescan Directory"
                    Padding="8,4"
                    Margin="0,8,0,0"
                    IsEnabled="{Binding CanRescan}"
                    Click="RescanButton_Click"/>

            <TreeView ItemsSource="{Binding Drives}"
                      BorderThickness="1"
                      BorderBrush="#CCCCCC">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="2"
                                    MouseLeftButtonUp="FolderItem_MouseLeftButtonUp"
                                    Background="Transparent">
                            <Image Width="16" Height="16" Margin="0,0,4,0">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Brush="#FFD54F" Geometry="M2,4 L10,4 L12,6 L18,6 L18,16 L2,16 Z">
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="#FFA000" Thickness="0.5"/>
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"/>

        <!-- Right Panel - File List -->
        <Grid Grid.Column="2" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,8">
                <Run Text="Files in: "/>
                <Run Text="{Binding SelectedPath, Mode=OneWay}" Foreground="#666666"/>
            </TextBlock>

            <!-- Total Size Display -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Total: " FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalSize, Converter={StaticResource FileSizeConverter}}"/>
                <TextBlock Text=" (" Margin="4,0,0,0"/>
                <TextBlock Text="{Binding Files.Count}"/>
                <TextBlock Text=" files in "/>
                <TextBlock Text="{Binding DirectoryGroups.Count}"/>
                <TextBlock Text=" directories, showing "/>
                <TextBlock Text="{Binding FilteredFileCount}"/>
                <TextBlock Text=")"/>
            </StackPanel>

            <!-- Search Box -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Search: "
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Padding="4,2"/>
                <Button Grid.Column="2"
                        Content="Clear"
                        Padding="8,2"
                        Margin="8,0,0,0"
                        Click="ClearSearch_Click"/>
            </Grid>

            <!-- Data Grid -->
            <DataGrid Grid.Row="3"
                      x:Name="FileDataGrid"
                      ItemsSource="{Binding FilteredFiles}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0E0E0"
                      BorderThickness="1"
                      BorderBrush="#CCCCCC"
                      CanUserSortColumns="True"
                      RowHeight="28"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="ContextMenu" Value="{StaticResource FileContextMenu}"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="24" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Rectangle Width="12" Height="12"
                                           Fill="{Binding Color}"
                                           RadiusX="2" RadiusY="2"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        SortMemberPath="Name"/>

                    <DataGridTextColumn Header="Size"
                                        Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                        Width="100"
                                        SortMemberPath="Size">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="%"
                                        Binding="{Binding Percentage, Converter={StaticResource PercentageConverter}}"
                                        Width="60"
                                        SortMemberPath="Percentage">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Horizontal Splitter -->
            <GridSplitter Grid.Row="4"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#E0E0E0"
                          Margin="0,4"/>

            <!-- Marimekko Chart at Bottom -->
            <Border Grid.Row="5"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Size Distribution by Directory (Marimekko Chart)"
                                   FontWeight="SemiBold"
                                   FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="Expand chart view to see individual files"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#666666"
                                   FontStyle="Italic"
                                   Visibility="{Binding ShowExpandChartMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- Marimekko Chart - Outer ItemsControl for Directories -->
                    <Grid Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding DirectoryGroups}"
                                      x:Name="MarimekkoChart"
                                      SizeChanged="MarimekkoChart_SizeChanged">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each directory column -->
                                <Border Margin="0,0,2,0"
                                        BorderBrush="#999999"
                                        BorderThickness="0.5"
                                        ToolTip="{Binding TooltipText}">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource ProportionalWidthConverter}">
                                            <Binding Path="Percentage"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                        </MultiBinding>
                                    </Border.Width>

                                    <Grid>
                                        <!-- Inner ItemsControl for Files within this directory -->
                                        <ItemsControl ItemsSource="{Binding ChartFiles}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Color}"
                                                            ToolTip="{Binding TooltipText}"
                                                            Margin="0,0,0,1"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="ChartSegment_MouseLeftButtonUp">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="White"/>
                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.Height>
                                                            <MultiBinding Converter="{StaticResource HeightConverter}">
                                                                <Binding Path="PercentageInDirectory"/>
                                                                <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl, AncestorLevel=2}"/>
                                                            </MultiBinding>
                                                        </Border.Height>
                                                    </Border>
                                                </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Size and file count label overlay -->
                                        <TextBlock Text="{Binding ChartLabel}"
                                                   FontSize="9"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Effect>
                                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.8"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Directory Labels and Percentages -->
                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding DirectoryGroups}"
                                  Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,2,0" ToolTip="{Binding Name}">
                                    <Grid.Width>
                                        <MultiBinding Converter="{StaticResource ProportionalWidthConverter}">
                                            <Binding Path="Percentage"/>
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                        </MultiBinding>
                                    </Grid.Width>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="9"
                                               Foreground="#666666"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding Percentage, Converter={StaticResource PercentageConverter}}"
                                               FontSize="9"
                                               Foreground="#999999"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Visibility="Collapsed"
              Grid.ColumnSpan="3"
              Background="#80FFFFFF">
            <Border Background="White"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="30,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="True"
                                 Width="100"
                                 Height="16"
                                 Margin="0,0,12,0"/>
                    <TextBlock Text="Rendering..."
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
