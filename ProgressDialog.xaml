<Window x:Class="FileSizeVisualizer.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scanning Files..."
        Height="180"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Scanning directory..."
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   x:Name="StatusText"
                   Text="Preparing..."
                   TextTrimming="CharacterEllipsis"
                   Foreground="#666666"
                   Margin="0,0,0,10"/>

        <ProgressBar Grid.Row="2"
                     x:Name="ProgressBar"
                     Height="20"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3"
                   x:Name="ProgressText"
                   Text="0 files found"
                   Foreground="#666666"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <Button Grid.Row="5"
                x:Name="CancelButton"
                Content="Cancel"
                Width="80"
                Height="28"
                HorizontalAlignment="Center"
                Click="CancelButton_Click"/>
    </Grid>
</Window>
